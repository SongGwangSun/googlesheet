# .env.example
# Google Apps Script 방식을 사용하는 경우 이 파일은 필요 없습니다.
# Node.js + Google Sheets API v4 방식으로 전환할 경우 아래 값을 설정하세요.

# Google Cloud 서비스 계정 키 파일 경로 (JSON)
GOOGLE_APPLICATION_CREDENTIALS=./service-account-key.json

# Google Spreadsheet ID (스프레드시트 URL에서 /d/ 뒤 문자열)
GOOGLE_SHEET_ID=your_spreadsheet_id_here

# 시트 이름
GOOGLE_SHEET_NAME=고객문의

# 서버 포트 (Node.js 방식)
PORT=3000
